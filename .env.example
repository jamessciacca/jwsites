# Public production URL. Set this to the final Vercel custom domain.
NEXT_PUBLIC_SITE_URL=https://jwsites.com

# Create an API key at https://resend.com/api-keys.
# Add the same value in Vercel: Project Settings → Environment Variables.
RESEND_API_KEY=re_your_api_key_here

# This must be an address on a domain verified in your Resend account.
# Example after verifying jwsites.com:
RESEND_FROM_EMAIL=website@jwsites.com
